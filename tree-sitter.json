{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "buildlog",
      "camelcase": "BuildLog",
      "title": "Build Log",
      "scope": "source.buildlog",
      "file-types": [],
      "injection-regex": "^buildlog$",
      "class-name": "TreeSitterBuildlog"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for parsing build logs",
    "authors": [
      {
        "name": "Nicholas Bishop",
        "email": "nbishop@nbishop.net",
        "url": "https://nbishop.net"
      }
    ],
    "links": {
      "repository": "https://github.com/nicholasbishop/tree-sitter-buildlog",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
