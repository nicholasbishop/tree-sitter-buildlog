{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "buildlog",
  "rules": {
    "log": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "diag"
          },
          {
            "type": "SYMBOL",
            "name": "junk_lines"
          }
        ]
      }
    },
    "junk_lines": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "_junk_line"
      }
    },
    "_junk_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_junk"
          }
        },
        {
          "type": "STRING",
          "value": "\n"
        }
      ]
    },
    "_junk": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "."
        }
      }
    },
    "diag": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_clang_diag"
        },
        {
          "type": "SYMBOL",
          "name": "_rust_diag"
        },
        {
          "type": "SYMBOL",
          "name": "_generic_diag"
        }
      ]
    },
    "_generic_diag": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "diag_level"
        },
        {
          "type": "STRING",
          "value": ": "
        },
        {
          "type": "SYMBOL",
          "name": "message"
        },
        {
          "type": "STRING",
          "value": "\n"
        }
      ]
    },
    "_clang_diag": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "source_ref"
        },
        {
          "type": "STRING",
          "value": ": "
        },
        {
          "type": "SYMBOL",
          "name": "diag_level"
        },
        {
          "type": "STRING",
          "value": ": "
        },
        {
          "type": "SYMBOL",
          "name": "message"
        },
        {
          "type": "STRING",
          "value": "\n"
        }
      ]
    },
    "_rust_diag": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "diag_level"
        },
        {
          "type": "SYMBOL",
          "name": "_rust_error_code"
        },
        {
          "type": "STRING",
          "value": ": "
        },
        {
          "type": "SYMBOL",
          "name": "message"
        },
        {
          "type": "STRING",
          "value": "\n  --> "
        },
        {
          "type": "SYMBOL",
          "name": "source_ref"
        },
        {
          "type": "STRING",
          "value": "\n"
        }
      ]
    },
    "message": {
      "type": "PATTERN",
      "value": ".*"
    },
    "source_ref": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[^\\n]+"
          },
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "PATTERN",
            "value": "\\d+"
          },
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "PATTERN",
            "value": "\\d+"
          }
        ]
      }
    },
    "_rust_error_code": {
      "type": "PATTERN",
      "value": "\\[E\\d+\\]"
    },
    "diag_level": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "error"
        },
        {
          "type": "STRING",
          "value": "warning"
        },
        {
          "type": "STRING",
          "value": "note"
        }
      ]
    }
  },
  "extras": [],
  "conflicts": [
    [
      "junk_lines"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}